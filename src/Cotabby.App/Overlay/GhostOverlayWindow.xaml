<Window x:Class="Cotabby.App.Overlay.GhostOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <StackPanel x:Name="GhostRow"
                Orientation="Horizontal"
                Background="Transparent">
        <TextBlock x:Name="GhostText"
                   Foreground="#A6FFFFFF"
                   FontFamily="Segoe UI Variable, Segoe UI, Segoe UI Symbol, Cascadia Mono, Consolas"
                   FontSize="14"
                   Text=""
                   TextOptions.TextRenderingMode="ClearType"
                   TextOptions.TextFormattingMode="Display"
                   TextWrapping="NoWrap"
                   VerticalAlignment="Center" />
        <Border x:Name="TabKeycap"
                Margin="6,0,0,0"
                Padding="5,1"
                CornerRadius="4"
                Background="#33FFFFFF"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                VerticalAlignment="Center">
            <TextBlock x:Name="TabKeycapLabel"
                       Text="Tab"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="Medium"
                       Foreground="#CCFFFFFF" />
        </Border>
    </StackPanel>
</Window>
