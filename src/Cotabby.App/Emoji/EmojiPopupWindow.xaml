<Window x:Class="Cotabby.App.Emoji.EmojiPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">
    <Border x:Name="Panel" CornerRadius="8" Padding="6,4"
            Background="#EE1F1F1F" BorderBrush="#FF3A3A3A" BorderThickness="1">
        <StackPanel x:Name="Items" Orientation="Vertical" />
    </Border>
</Window>
