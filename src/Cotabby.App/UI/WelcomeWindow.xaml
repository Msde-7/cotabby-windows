<Window x:Class="Cotabby.App.UI.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Cotabby"
        Width="640"
        Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF1B1B1B"
        Foreground="#FFE8E8E8">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#FF2159C8" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE8E8E8" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE8E8E8" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF252525" />
            <Setter Property="Foreground" Value="#FFE8E8E8" />
            <Setter Property="BorderBrush" Value="#FF3A3A3A" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF252525" />
            <Setter Property="Foreground" Value="#FFE8E8E8" />
            <Setter Property="BorderBrush" Value="#FF3A3A3A" />
            <Setter Property="Padding" Value="6,2" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Background" Value="#FF252525" />
            <Setter Property="Foreground" Value="#FFE8E8E8" />
            <Setter Property="BorderBrush" Value="#FF3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header / step indicator -->
        <Border Grid.Row="0" Background="#FF222222" Padding="24,16">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="StepTitle" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock x:Name="StepSubtitle" FontSize="12" Margin="0,4,0,0" Opacity="0.7" />
                </StackPanel>
                <TextBlock x:Name="StepIndex" HorizontalAlignment="Right" VerticalAlignment="Top"
                           FontSize="11" Opacity="0.7" />
            </Grid>
        </Border>

        <!-- Step body -->
        <Grid Grid.Row="1" Margin="24,20,24,20">
            <!-- Step 1: Welcome -->
            <StackPanel x:Name="StepWelcome">
                <TextBlock Text="What Cotabby does"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock TextWrapping="Wrap" Opacity="0.85"
                           Text="Cotabby watches the text field you are typing in and quietly proposes a continuation as faint ghost text next to your cursor. Press Tab to accept the next word, keep pressing to take more, or just keep typing to ignore it." />

                <TextBlock Text="What stays on your machine"
                           FontSize="14" FontWeight="SemiBold" Margin="0,18,0,6" />
                <TextBlock TextWrapping="Wrap" Opacity="0.85"
                           Text="All inference runs on this machine via llama.cpp. There is no hosted API, no telemetry, and no keystroke leaves Cotabby once you turn it off in the tray." />

                <TextBlock Text="How it integrates"
                           FontSize="14" FontWeight="SemiBold" Margin="0,18,0,6" />
                <TextBlock TextWrapping="Wrap" Opacity="0.85"
                           Text="Cotabby uses standard Windows UI Automation to find the focused field, a low-level keyboard hook to detect Tab without grabbing focus, and a tiny tray icon. No drivers, no admin rights required." />
            </StackPanel>

            <!-- Step 2: Profile -->
            <StackPanel x:Name="StepProfile" Visibility="Collapsed">
                <TextBlock Text="Your name (optional)" Margin="0,0,0,4" />
                <TextBox x:Name="NameBox" Width="320" HorizontalAlignment="Left" />
                <TextBlock Margin="0,4,0,0" FontSize="11" Opacity="0.6"
                           TextWrapping="Wrap"
                           Text="Used to keep suggestions sounding like you in chat/email contexts where the host gives Cotabby little to go on." />

                <TextBlock Margin="0,18,0,4" Text="Primary languages (comma-separated)" />
                <TextBox x:Name="LanguagesBox" Width="420" HorizontalAlignment="Left" Text="English" />
                <TextBlock Margin="0,4,0,0" FontSize="11" Opacity="0.6"
                           Text="Cotabby will lean toward writing in these. First one wins for tie-breaks." />

                <TextBlock Margin="0,18,0,4" Text="Completion length" />
                <ComboBox x:Name="LengthCombo" Width="320" HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Step 3: Model -->
            <StackPanel x:Name="StepModel" Visibility="Collapsed">
                <TextBlock Text="Pick a model" FontWeight="SemiBold" FontSize="14" />
                <TextBlock Margin="0,4,0,12" Opacity="0.75" TextWrapping="Wrap"
                           Text="Smaller is snappier. Larger is smarter. You can change this any time from Settings or the tray. Nothing downloads automatically — you'll start the download from the Engine &amp; model tab whenever you're ready." />
                <ListBox x:Name="ModelChoiceList" Height="220"
                         Background="#FF252525" Foreground="#FFE8E8E8"
                         BorderBrush="#FF3A3A3A">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,8">
                                <TextBlock Text="{Binding DisplayName}" FontSize="14" />
                                <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Opacity="0.65" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Step 4: Behavior / appearance -->
            <StackPanel x:Name="StepBehavior" Visibility="Collapsed">
                <TextBlock Text="Defaults you can change later"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                <CheckBox x:Name="LaunchAtLoginCheck" Content="Start Cotabby when I sign in" />
                <CheckBox x:Name="EmojiCheck" Content="Inline emoji picker (`:smile`, `:tada`, etc.)" />
                <CheckBox x:Name="MultiLineCheck" Content="Allow multi-line suggestions" />
                <CheckBox x:Name="ShowHintCheck" Content="Show acceptance key hint next to ghost text" />

                <TextBlock Margin="0,18,0,4" Text="Ghost text color" />
                <ComboBox x:Name="ColorCombo" Width="280" HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Step 5: Ready -->
            <StackPanel x:Name="StepReady" Visibility="Collapsed">
                <TextBlock Text="You're ready" FontSize="14" FontWeight="SemiBold" />
                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Opacity="0.85"
                           Text="Cotabby lives in your system tray. Right-click the icon for Settings, model switching, diagnostics, and the enable toggle. The first time you focus a text field after loading a model, ghost text will appear right next to your cursor — press Tab to accept the next word." />
                <TextBlock Margin="0,16,0,0" FontSize="12" Opacity="0.7"
                           TextWrapping="Wrap"
                           Text="Tip: if Cotabby ever feels wrong in a specific app, add that app under Settings → Apps and we'll stop suggesting there." />
            </StackPanel>
        </Grid>

        <!-- Footer / nav -->
        <Border Grid.Row="2" Background="#FF222222" Padding="24,12">
            <Grid>
                <Button x:Name="SkipButton" Content="Skip setup" Click="OnSkip"
                        HorizontalAlignment="Left" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BackButton" Content="Back" Click="OnBack" Margin="0,0,8,0" />
                    <Button x:Name="NextButton" Content="Next" Click="OnNext"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
