<Window x:Class="Cotabby.App.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cotabby Settings"
        Width="760"
        Height="560"
        MinWidth="640"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E"
        Foreground="#FFE0E0E0">
    <Window.Resources>
        <SolidColorBrush x:Key="Surface" Color="#FF1E1E1E" />
        <SolidColorBrush x:Key="SurfaceAlt" Color="#FF252525" />
        <SolidColorBrush x:Key="SurfaceList" Color="#FF2A2A2A" />
        <SolidColorBrush x:Key="Border" Color="#FF3A3A3A" />
        <SolidColorBrush x:Key="Foreground" Color="#FFE0E0E0" />
        <SolidColorBrush x:Key="Muted" Color="#FFA0A0A0" />
        <SolidColorBrush x:Key="Accent" Color="#FF2159C8" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Foreground}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Foreground}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource Foreground}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Margin" Value="0,4,12,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}" />
            <Setter Property="Foreground" Value="{StaticResource Foreground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}" />
            <Setter Property="Foreground" Value="{StaticResource Foreground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Padding" Value="8,3" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}" />
            <Setter Property="Foreground" Value="{StaticResource Foreground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SurfaceList}" />
            <Setter Property="Foreground" Value="{StaticResource Foreground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,4,0,8" />
        </Style>
        <Style x:Key="SubLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Foreground}" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Padding="14,8" Margin="0,0,0,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceAlt}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,16,20,4">
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Cotabby" />
            <TextBlock Style="{StaticResource SubLabel}" Margin="0,2,0,0"
                       Text="Local AI autocomplete for Windows. All processing stays on this machine." />
        </StackPanel>

        <TabControl x:Name="Tabs" Grid.Row="1" Margin="20,8,20,8">
            <!-- =========================== GENERAL =========================== -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,12,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Behavior" />

                        <CheckBox x:Name="EnabledCheck" Content="Enable Cotabby globally" />
                        <CheckBox x:Name="LaunchAtLoginCheck" Content="Start Cotabby when I sign in" />
                        <CheckBox x:Name="EmojiPickerCheck"
                                  Content="Inline emoji picker (`:smile`, `:tada`, etc.)" />
                        <CheckBox x:Name="MultiLineCheck"
                                  Content="Allow multi-line suggestions" />
                        <CheckBox x:Name="AcceptPunctuationCheck"
                                  Content="Accept punctuation when accepting a word" />
                        <CheckBox x:Name="ShowHintCheck"
                                  Content="Show acceptance key hint next to ghost text" />
                        <CheckBox x:Name="FastModeCheck"
                                  Content="Fast mode (skip slower context gathering)" />

                        <TextBlock Style="{StaticResource SectionHeader}" Margin="0,18,0,8"
                                   Text="Suggestion appearance" />

                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ghost text color" VerticalAlignment="Center" />
                            <ComboBox x:Name="ColorCombo" Grid.Column="1" Width="220" HorizontalAlignment="Left" />
                        </Grid>

                        <Grid Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ghost text opacity" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="OpacitySlider" Width="220" Minimum="0.30" Maximum="1.00"
                                        SmallChange="0.05" TickFrequency="0.10"
                                        IsSnapToTickEnabled="True"
                                        Value="1.0" />
                                <TextBlock x:Name="OpacityLabel" VerticalAlignment="Center"
                                           Margin="10,0,0,0" Text="100%" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Display mode" VerticalAlignment="Center" />
                            <ComboBox x:Name="DisplayModeCombo" Grid.Column="1" Width="220" HorizontalAlignment="Left" />
                        </Grid>

                        <TextBlock Style="{StaticResource SubLabel}" Margin="0,8,0,0"
                                   Text="The popup mode is reserved for fields where caret geometry is unreliable; on Windows it currently falls back to inline." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =========================== ENGINE & MODEL =========================== -->
            <TabItem Header="Engine &amp; model">
                <Grid Margin="4,12,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}" Text="Model" />
                    <TextBlock Grid.Row="1" Style="{StaticResource SubLabel}"
                               Text="Pick a local GGUF model. Downloads to %LOCALAPPDATA%\Cotabby\models. Larger models give better suggestions but use more RAM and CPU." />

                    <ListBox x:Name="ModelList" Grid.Row="2" SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6,8">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" />
                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Opacity="0.65" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ProgressBar x:Name="DownloadProgress" Grid.Row="3" Margin="0,10,0,4"
                                 Height="6" Minimum="0" Maximum="1" Value="0"
                                 Visibility="Collapsed" />
                    <TextBlock x:Name="ModelStatusText" Grid.Row="4" Margin="0,4,0,12"
                               FontSize="12" Opacity="0.85" />

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="UseButton" Content="Download / use selected"
                                Style="{StaticResource PrimaryButton}" Click="OnUseModel" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- =========================== WRITING =========================== -->
            <TabItem Header="Writing">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,12,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Completion length" />
                        <TextBlock Style="{StaticResource SubLabel}"
                                   Text="How much continuation Cotabby shows by default. Shorter feels snappier; longer reduces how often you have to keep hitting Tab." />
                        <ComboBox x:Name="LengthCombo" Width="280" HorizontalAlignment="Left" />

                        <TextBlock Style="{StaticResource SectionHeader}" Margin="0,18,0,8"
                                   Text="Your profile" />
                        <TextBlock Style="{StaticResource SubLabel}"
                                   Text="Used to keep suggestions in your voice when the host app provides little context." />

                        <TextBlock Margin="0,4,0,2" Text="Name" />
                        <TextBox x:Name="UserNameBox" Width="280" HorizontalAlignment="Left" />

                        <TextBlock Margin="0,12,0,2" Text="Languages (comma-separated)" />
                        <TextBox x:Name="LanguagesBox" Width="380" HorizontalAlignment="Left" />
                        <TextBlock Style="{StaticResource SubLabel}" Margin="0,4,0,0"
                                   Text="Example: English, Spanish. The first entry is treated as primary." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =========================== SHORTCUTS =========================== -->
            <TabItem Header="Shortcuts">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,12,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Acceptance" />
                        <TextBlock Style="{StaticResource SubLabel}"
                                   Text="Tab is currently the only acceptance key supported on Windows — eating other keys before the host sees them requires per-key registration we don't ship yet. The fields below capture your intent for future versions." />

                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Accept next word" VerticalAlignment="Center" />
                            <TextBox x:Name="AcceptWordKeyBox" Grid.Column="1"
                                     Width="160" HorizontalAlignment="Left" IsReadOnly="True"
                                     Text="Tab" />
                        </Grid>

                        <Grid Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Accept whole suggestion" VerticalAlignment="Center" />
                            <TextBox x:Name="AcceptSuggestionKeyBox" Grid.Column="1"
                                     Width="160" HorizontalAlignment="Left" />
                        </Grid>

                        <Grid Margin="0,8,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Toggle Cotabby globally" VerticalAlignment="Center" />
                            <TextBox x:Name="GlobalToggleKeyBox" Grid.Column="1"
                                     Width="160" HorizontalAlignment="Left" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =========================== APPS =========================== -->
            <TabItem Header="Apps">
                <Grid Margin="4,12,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}" Text="Disable in specific apps" />
                    <TextBlock Grid.Row="1" Style="{StaticResource SubLabel}"
                               Text="Cotabby will not suggest in these apps even when enabled. Use the process name without .exe (e.g. `keepass`, `chrome`, `Code`)." />

                    <ListBox x:Name="BlockedAppsList" Grid.Row="2" />

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewAppBox" Grid.Column="0" />
                        <Button Grid.Column="1" Margin="8,0,0,0" Content="Add"
                                Click="OnAddBlockedApp" />
                        <Button Grid.Column="2" Margin="8,0,0,0" Content="Remove selected"
                                Click="OnRemoveBlockedApp" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- =========================== ADVANCED =========================== -->
            <TabItem Header="Advanced">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,12,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Performance" />

                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Trigger debounce (ms)" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="DebounceSlider" Width="260"
                                        Minimum="20" Maximum="500" SmallChange="10"
                                        TickFrequency="20" IsSnapToTickEnabled="True"
                                        Value="80" />
                                <TextBlock x:Name="DebounceLabel" VerticalAlignment="Center"
                                           Margin="10,0,0,0" Text="80 ms" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Style="{StaticResource SubLabel}" Margin="0,4,0,0"
                                   Text="Lower values feel snappier; higher values reduce engine work while you're typing in bursts. Changes apply at the next request." />

                        <TextBlock Style="{StaticResource SectionHeader}" Margin="0,18,0,8" Text="Storage" />
                        <TextBlock x:Name="SettingsPathText" Style="{StaticResource SubLabel}" />
                        <TextBlock x:Name="ModelsPathText" Style="{StaticResource SubLabel}" />
                        <TextBlock x:Name="LogPathText" Style="{StaticResource SubLabel}" />

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Open models folder" Click="OnOpenModelsFolder" />
                            <Button Content="Open log" Margin="8,0,0,0" Click="OnOpenLog" />
                            <Button Content="Open settings file" Margin="8,0,0,0" Click="OnOpenSettingsFile" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =========================== ABOUT =========================== -->
            <TabItem Header="About">
                <StackPanel Margin="4,12,12,12">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="Cotabby for Windows" />
                    <TextBlock x:Name="VersionText" Style="{StaticResource SubLabel}" Margin="0,4,0,0" />
                    <TextBlock Style="{StaticResource SubLabel}" Margin="0,12,0,0"
                               Text="Local AI autocomplete for Windows 10 / 11. Native port of FuJacob/cotabby (macOS) — same suggestion behavior, same model files, all inference on-device via llama.cpp." />
                    <TextBlock Style="{StaticResource SubLabel}" Margin="0,12,0,0"
                               Text="License: GNU AGPL v3.0" />
                    <TextBlock Style="{StaticResource SubLabel}" Margin="0,12,0,0"
                               Text="Upstream: github.com/FuJacob/cotabby&#10;Windows port: github.com/Msde-7/cotabby-windows" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <TextBlock x:Name="FooterStatus" VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource Muted}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Close" Click="OnClose" />
                    <Button x:Name="SaveButton" Content="Save" Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0" Click="OnSave" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
